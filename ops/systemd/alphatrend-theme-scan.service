[Unit]
Description=AlphaTrend V3 full theme scan orchestration
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/srv/alphatrend
EnvironmentFile=/srv/alphatrend/.env
ExecStartPre=/usr/bin/env npm run ops:provider-smoke-gate -- --max-age-minutes=180
ExecStart=/usr/bin/env npm run job:theme-scan -- --all --demand=off
