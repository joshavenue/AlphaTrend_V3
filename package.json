    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.7.4",
    "prisma": "^7.2.0",
