{
  "name": "alphatrend-v3",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 420",
    "postinstall": "prisma generate",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 420",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "rm -rf .next/types .next/dev/types && tsc --noEmit",
    "pretest": "tsx scripts/test-db-guard.ts",
    "test": "vitest run",
    "pretest:unit": "tsx scripts/test-db-guard.ts",
    "test:unit": "vitest run tests/unit",
    "pretest:integration": "tsx scripts/test-db-guard.ts --require-db",
    "test:integration": "V3_REQUIRE_DATABASE=1 vitest run tests/integration",
    "pretest:regression": "tsx scripts/test-db-guard.ts",
    "test:regression": "vitest run tests/regression",
    "pretest:ui": "tsx scripts/test-db-guard.ts --require-db",
    "test:ui": "playwright test",
    "pretest:coverage": "tsx scripts/test-db-guard.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:backup": "tsx scripts/db-backup.ts",
    "db:rollback": "tsx scripts/db-rollback.ts",
    "db:health": "tsx scripts/db-health.ts",
    "health": "tsx scripts/health.ts",
    "admin:create": "tsx scripts/admin-create.ts",
    "smoke:providers": "tsx scripts/smoke-providers.ts",
    "job:security-master": "tsx scripts/security-master-refresh.ts",
    "themes:validate": "tsx scripts/themes.ts validate",
    "themes:load": "tsx scripts/themes.ts load",
    "themes:list": "tsx scripts/themes.ts list",
    "theme-seeds:validate": "tsx scripts/theme-seeds.ts validate",
    "theme-seeds:load": "tsx scripts/theme-seeds.ts load",
    "candidates:generate": "tsx scripts/candidates-generate.ts",
    "candidates:report": "tsx scripts/candidates-report.ts",
    "exposure:score": "tsx scripts/exposure-score.ts",
    "exposure:report": "tsx scripts/exposure-report.ts",
    "fundamentals:score": "tsx scripts/fundamentals-score.ts",
    "fundamentals:report": "tsx scripts/fundamentals-report.ts",
    "price:score": "tsx scripts/price-score.ts",
    "price:report": "tsx scripts/price-report.ts",
    "liquidity:score": "tsx scripts/liquidity-score.ts",
    "liquidity:report": "tsx scripts/liquidity-report.ts",
    "expression:score": "tsx scripts/expression-score.ts",
    "expression:report": "tsx scripts/expression-report.ts",
    "advanced:score": "tsx scripts/advanced-score.ts",
    "ownership:score": "tsx scripts/advanced-score.ts --layer=t5",
    "base-rate:score": "tsx scripts/advanced-score.ts --layer=t7",
    "snapshots:build": "tsx scripts/snapshots-build.ts",
    "snapshots:report": "tsx scripts/snapshots-report.ts",
    "demand:fetch": "tsx scripts/demand-fetch.ts",
    "demand:score": "tsx scripts/demand-score.ts",
    "demand:report": "tsx scripts/demand-report.ts",
    "job:theme-scan": "tsx scripts/theme-scan.ts --all",
    "job:demand": "tsx scripts/demand-job.ts --all",
    "job:snapshots": "tsx scripts/snapshots-build.ts --all",
    "alerts:evaluate": "tsx scripts/alerts-evaluate.ts",
    "alerts:list": "tsx scripts/alerts-list.ts",
    "job:alerts": "tsx scripts/alerts-evaluate.ts --all",
    "ops:provider-smoke-gate": "tsx scripts/provider-smoke-gate.ts",
    "ops:runtime-authority": "tsx scripts/runtime-authority.ts",
    "smoke:ui": "tsx scripts/phase15-ui-smoke.ts",
    "verify:docs": "tsx scripts/verify-docs.ts"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.2.0",
    "dotenv": "^17.2.3",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.15.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.7.4",
    "prisma": "^7.2.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
